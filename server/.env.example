# This file is a TEMPLATE and IS committed to the repo.
# The real key goes into a .env file (which is in .gitignore).
# Setup: copy this file to .env and fill in the value.

GEMINI_API_KEY=your_gemini_api_key_here

# --- Rate limiting (all optional; sensible defaults if omitted) ---
# Per-IP and global analyses allowed per day.
# RATE_LIMIT_PER_IP=3
# RATE_LIMIT_GLOBAL=18
# Comma-separated IPs that bypass the limits (the operator). Defaults to
# localhost so local development is never throttled.
# RATE_LIMIT_EXEMPT_IPS=127.0.0.1,::1,localhost
