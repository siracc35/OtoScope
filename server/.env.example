# Bu dosya şablondur ve repoya commit edilir.
# Gerçek değerler: Railway'de "Variables" sekmesinde, ya da local'de .env dosyasına.
# Kurulum: bu dosyayı .env olarak kopyala ve doldur.

GEMINI_API_KEY=your_gemini_api_key_here

# Production'da frontend ve backend aynı domain'deyse bu boş bırakılabilir.
# Ayrı domain kullanılıyorsa virgülle ayır: https://example.com,https://www.example.com
# ALLOWED_ORIGINS=*

# --- Telegram Bot (optional) ---
# Get a token from @BotFather on Telegram, then set it here.
# Run the bot with: python bot.py
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# BOT_API_URL=http://127.0.0.1:8000

# --- Rate limiting (all optional; sensible defaults if omitted) ---
# Per-IP and global analyses allowed per day.
# RATE_LIMIT_PER_IP=3
# RATE_LIMIT_GLOBAL=18
# Comma-separated IPs that bypass the limits (the operator). Defaults to
# localhost so local development is never throttled.
# RATE_LIMIT_EXEMPT_IPS=127.0.0.1,::1,localhost
